// Zapstore — schema multi-tenant com Row-Level Security.
//
// Toda tabela de domínio (Product, Order, etc) tem `tenantId` indexado.
// A RLS é habilitada em migração SQL separada (00000000000000_init_rls).
// Cada requisição precisa executar `SET LOCAL app.tenant_id = '<uuid>'`
// (use o helper `withTenant` em packages/db/src/index.ts).

generator client {
  provider      = "prisma-client-js"
  // native = dev (Windows/Mac); linux-musl-openssl-3.0.x = container Alpine (deploy).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PLATAFORMA (sem tenantId — tabelas globais)
// ============================================================

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  niche       String?  // colchoes_moveis | estetica | generico (TRAVADO após cadastro; só super-admin troca)
  enabledModules String[] @default([]) // módulos ativos: products|delivery|scheduling|fiscal (nicho define base + perguntas no cadastro)
  brandColor  String?  // cor da marca (white-label básico), ex: "#16a34a"
  logoUrl     String?  // logo completa (vai pro Focus/DANFE e impressão)
  iconUrl     String?  // ícone quadrado da loja (usado no menu lateral)
  pixKey      String?  // chave Pix do lojista (p/ gerar QR no pedido)
  pixCity     String?  // cidade do recebedor (p/ o código Pix)
  defaultMarginPct Decimal? @db.Decimal(5, 2) // margem padrão (% sobre a venda) p/ auto-preencher preço
  roundTo90   Boolean  @default(false) // arredondar preço sugerido p/ terminar em ,90
  cardFeePct  Decimal? @db.Decimal(5, 2) // DEPRECADO (substituído por cardFees); mantido p/ compat
  cardFees    Json?    // taxas: { pix, debit, credit: [{n, fee}] } — % por forma/parcela
  settlement  Json?    // repasse da maquininha: { pixDays, debitDays, creditMode, creditAdvanceDays, boletoDays, anticipationFeePct }
  taxEstimatePct Decimal? @db.Decimal(5, 2) // imposto estimado sobre vendas com nota (% p/ caixa)
  salesGoalBrl Decimal? @db.Decimal(12, 2) // meta de vendas mensal (módulo "goal" opcional)
  marketingKeywords Json? // frases-chave de origem de lead: { meta: string[], google: string[] }
  primaryFocus String? // atividade principal quando vende E agenda: "products" | "scheduling" (prioriza menu/terminologia)
  managementPinHash String? // senha de gestao (salt:hash scrypt) — exigida pra editar/excluir registros
  status      TenantStatus @default(TRIAL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         TenantUser[]
  subscription  Subscription?
  botConfig     BotConfig?
  products      Product[]
  orders        Order[]
  conversations Conversation[]
  usageEvents   UsageEvent[]
  customers     Customer[]
  professionals Professional[]
  services      Service[]
  appointments  Appointment[]
  expenses      Expense[]
  productKitItems ProductKitItem[]
  marketingSpends MarketingSpend[]
  fiscalConfig  FiscalConfig?
  anticipations Anticipation[]

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELED
}

// Configurações globais da plataforma (chaves de API editáveis pelo super-admin).
// Sem tenantId/RLS — é global. Lido por getPlatformSetting() com fallback pro env.
model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenants  TenantUser[]
  sessions Session[]
  accounts Account[]

  @@map("users")
}

// ============================================================
// AUTH (Better-Auth schema)
// ============================================================

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model TenantUser {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  role      TenantRole @default(ADMIN)
  permissions Json?   // perfil personalizado: lista de áreas; null = usa o preset do role
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

enum TenantRole {
  ADMIN
  MANAGER
  OPERATOR
  FINANCIAL
  DELIVERY
}

model Subscription {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @unique @db.Uuid
  provider        String   // "asaas" | "stripe"
  providerSubId   String?
  plan            String   // "starter" | "pro"
  monthlyPriceBrl Decimal  @db.Decimal(10, 2)
  messageQuota    Int      // 2500 no plano starter
  status          String   // "trialing" | "active" | "past_due" | "canceled"
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================================
// CONFIGURAÇÃO DO BOT POR TENANT
// ============================================================

model BotConfig {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @unique @db.Uuid

  // Identidade
  botName            String   // "Gustavo"
  tone               String   @default("professional_casual")
  template           String   @default("generico") // template do nicho

  // Operação
  businessHours      Json     // { mon: { open: "08:00", close: "18:00" }, ... }
  deliveryCities     String[] // ["Goiânia", "Aparecida", "Senador Canedo"]
  paymentMethods     String[] // ["pix", "cartao", "boleto"]
  acceptsScheduling  Boolean  @default(false)
  dailyDeliveryCapacity Int   @default(0) // entregas/dia (0 = sem limite definido)
  morningCutoff   String? // horário de corte do turno manhã (HH:MM; null = padrão 12:00)
  afternoonCutoff String? // horário de corte do turno tarde (HH:MM; null = padrão 18:00)
  weeklyCapacity  Json?   // capacidade por dia da semana × turno: { "0".."6": { morning, afternoon } } (0=domingo; 0=não entrega; null=sem limite)

  // Prompt customizado pelo lojista
  extraInstructions  String   @default("") @db.Text

  // Conexão WhatsApp
  whatsappProvider   String   @default("evolution") // "evolution" | "meta_cloud"
  whatsappInstance   String?  // nome da instance Evolution ou phone_number_id Meta
  whatsappConnected  Boolean  @default(false)

  // LLM
  llmProvider        String   @default("google") // "anthropic" | "google" | "openai"
  llmModel           String   @default("gemini-2.5-flash")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("bot_configs")
}

// ============================================================
// DOMÍNIO (todas com tenantId)
// ============================================================

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String   // nome comercial (mostrado ao cliente/bot)
  fiscalName  String?  // nome da nota (p/ emissão fiscal); idealmente não editado após emitir
  description String?  @db.Text
  category    String?  // categoria livre (ou por nicho): "Casal", "Queen"...
  kind        String   @default("simple") // "simple" | "kit"
  priceBrl    Decimal  @db.Decimal(10, 2)
  costBrl     Decimal? @db.Decimal(10, 2) // custo, pra calcular margem
  imageUrl    String?  // imagem de catálogo
  realImageUrl String? // imagem "real" do produto
  stock       Int      @default(0)
  lowStockThreshold Int @default(5) // alerta quando stock <= este valor
  // Dados fiscais (estrutura pronta; emissão de nota vem no módulo fiscal)
  ncm         String?
  cest        String?
  cfopEntrada String?
  origem      String?  // origem da mercadoria (0-8)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kitItems   ProductKitItem[] @relation("KitComposition")
  partOfKits ProductKitItem[] @relation("KitComponentOf")

  @@index([tenantId, active])
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  phone     String
  email     String?
  address   String?  @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Telefone é a chave natural do cliente (sistema é centrado em WhatsApp);
  // único por tenant pra permitir casar histórico de pedidos por telefone.
  @@unique([tenantId, phone])
  @@index([tenantId, createdAt])
  @@map("customers")
}

model ProductKitItem {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  kitId       String  @db.Uuid // produto tipo kit
  componentId String  @db.Uuid // produto componente
  qty         Int     @default(1)

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kit       Product @relation("KitComposition", fields: [kitId], references: [id], onDelete: Cascade)
  component Product @relation("KitComponentOf", fields: [componentId], references: [id], onDelete: Cascade)

  @@index([tenantId, kitId])
  @@map("product_kit_items")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  orderNumber     Int         // sequencial por tenant
  customerName    String
  customerPhone   String
  customerAddress String?     @db.Text // endereço montado (compatibilidade/exibição)
  // Cliente — identidade
  customerCpf     String?
  customerEmail   String?
  // Endereço estruturado
  cep             String?
  street          String?
  streetNumber    String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  // Venda — metadados
  channel         String      @default("presencial") // "online" | "presencial"
  sellerName      String? // responsável pela venda
  invoiceType     String      @default("none") // "none" | "nfce" | "nfe"
  toReceive       Boolean     @default(false) // a receber (ex: na entrega)
  // Entrega
  deliveryType    String      @default("delivery") // "delivery" | "pickup"
  deliveryDate    DateTime?
  deliveryShift   String? // "morning" | "afternoon"
  leadSource      String? // origem de marketing: "meta" | "google" (herdada da conversa ou manual)
  // Valores
  status          OrderStatus @default(PENDING)
  items           Json        // [{ productId, name, qty, priceBrl, discountBrl, freightBrl }]
  discountBrl     Decimal?    @db.Decimal(10, 2)
  freightBrl      Decimal?    @db.Decimal(10, 2)
  totalBrl        Decimal     @db.Decimal(10, 2)
  paymentMethod   String?
  installments    Int         @default(1) // parcelas (cartão)
  notes           String?     @db.Text
  scheduledFor    DateTime?
  // Rota do dia (entrega)
  routeSeq        Int         @default(0) // ordem da parada na rota
  routeStatus     String?     // pending | en_route | at_door | delivered | skipped | absent
  // Fiscal (emissão via Focus)
  fiscalModel     String?     // "nfce" | "nfe"
  fiscalRef       String?     // referência única enviada ao Focus
  fiscalStatus    String?     // processando | autorizado | erro_autorizacao | cancelado
  fiscalChave     String?
  fiscalNumero    String?
  fiscalDanfeUrl  String?     @db.Text
  fiscalXmlUrl    String?     @db.Text
  fiscalMessage   String?     @db.Text
  fiscalAt        DateTime?
  // Antecipação dos recebíveis de cartão (eventos futuros viram caixa na data abaixo)
  cardAnticipatedAt     DateTime?
  cardAnticipationFeePct Decimal? @db.Decimal(5, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status, createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_DELIVERY
  DELIVERED
  CANCELED
}

model Anticipation {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  grossBrl  Decimal  @db.Decimal(12, 2) // recebível antecipado (líquido de taxa de cartão)
  feePct    Decimal  @db.Decimal(5, 2)  // taxa de antecipação aplicada
  costBrl   Decimal  @db.Decimal(12, 2) // custo da antecipação
  netBrl    Decimal  @db.Decimal(12, 2) // líquido recebido na antecipação
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("anticipations")
}

model Conversation {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  customerPhone   String
  customerName    String?
  lastMessageAt   DateTime @default(now())
  botPaused       Boolean  @default(false)
  botPausedUntil  DateTime?
  optOut          Boolean  @default(false)
  leadSource      String?  // origem do lead detectada por frase-chave: "meta" | "google"
  createdAt       DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([tenantId, customerPhone])
  @@index([tenantId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  role           String   // "user" | "assistant" | "system"
  content        String   @db.Text
  mediaType      String?  // "audio" | "image" | "pdf" | null
  mediaUrl       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model UsageEvent {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tokensIn     Int
  tokensOut    Int
  messageCount Int      @default(1)
  costBrl      Decimal  @db.Decimal(10, 4)
  llmProvider  String
  llmModel     String
  occurredAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
  @@map("usage_events")
}

// ============================================================
// AGENDAMENTO DE SERVIÇOS (nichos de serviço: estética, clínica...)
// ============================================================

model Professional {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  active    Boolean  @default(true)
  // Em lojas que vendem E atendem, a pessoa pode ser vendedor, profissional ou ambos.
  // Vendedor aparece na lista do PEDIDO; profissional aparece na AGENDA.
  isSeller       Boolean @default(true)
  isProfessional Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId, active])
  @@map("professionals")
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  durationMin Int      @default(30)
  priceBrl    Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId, active])
  @@map("services")
}

model Appointment {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @db.Uuid
  professionalId String?           @db.Uuid
  serviceId      String?           @db.Uuid
  serviceName    String            // snapshot do serviço no momento
  customerName   String
  customerPhone  String
  scheduledFor   DateTime
  durationMin    Int               @default(30)
  priceBrl       Decimal           @default(0) @db.Decimal(10, 2)
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?           @db.Text
  orderId        String?           @db.Uuid // venda gerada ao concluir (atendimento realizado = venda)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, scheduledFor])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  DONE
  CANCELED
  NO_SHOW
}

// ============================================================
// FINANCEIRO
// ============================================================

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  category    String   // "Fornecedor", "Aluguel", "Marketing", "Salário"...
  description String?
  amountBrl   Decimal  @db.Decimal(10, 2)
  paidAt      DateTime // data da despesa (competência)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, paidAt])
  @@map("expenses")
}

// ============================================================
// MARKETING (investimento em anúncios por canal/mês)
// ============================================================

model MarketingSpend {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  month     DateTime // 1º dia do mês de competência
  channel   String   // "meta" | "google" | "outros" (ou livre)
  amountBrl Decimal  @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, month])
  @@map("marketing_spends")
}

// ============================================================
// FISCAL (emissão de nota via Focus NFe — módulo pago)
// ============================================================

model FiscalConfig {
  id                String  @id @default(uuid()) @db.Uuid
  tenantId          String  @unique @db.Uuid

  // Emitente
  cnpj              String
  razaoSocial       String
  nomeFantasia      String?
  inscricaoEstadual String?
  regimeTributario  Int     @default(1) // 1=Simples Nacional, 2=Simples excesso, 3=Normal
  email             String?
  telefone          String?

  // Endereço do emitente
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  municipio         String?
  codigoMunicipio   String?
  uf                String?

  // Emissão
  ambiente          String  @default("homologacao") // "homologacao" | "producao"
  habilitaNfce      Boolean @default(true)
  habilitaNfe       Boolean @default(true)

  // CSC da NFC-e (produção) — fornecido pela SEFAZ do estado
  cscNfceProd       String?
  idTokenNfceProd   String?

  // Numeração das notas (migração de outro sistema: série + PRÓXIMO número por documento/ambiente)
  serieNfeHomolog     Int?
  proxNumNfeHomolog   Int?
  serieNfeProd        Int?
  proxNumNfeProd      Int?
  serieNfceHomolog    Int?
  proxNumNfceHomolog  Int?
  serieNfceProd       Int?
  proxNumNfceProd     Int?
  cfopPadrao        String? // CFOP de venda padrão (ex: 5102)
  csosnPadrao       String? // CSOSN padrão p/ Simples (ex: 102)

  // Integração Focus (por empresa)
  focusEmpresaId    Int?
  focusTokenHomolog String?
  focusTokenProd    String?

  // Certificado (NUNCA guardamos o .pfx; só metadados retornados pelo Focus)
  certCnpj          String?
  certValidoAte     DateTime?
  certStatus        String?  // "ok" | "erro" | null

  enabled           Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("fiscal_configs")
}
