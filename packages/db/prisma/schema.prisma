// Zapstore — schema multi-tenant com Row-Level Security.
//
// Toda tabela de domínio (Product, Order, etc) tem `tenantId` indexado.
// A RLS é habilitada em migração SQL separada (00000000000000_init_rls).
// Cada requisição precisa executar `SET LOCAL app.tenant_id = '<uuid>'`
// (use o helper `withTenant` em packages/db/src/index.ts).

generator client {
  provider      = "prisma-client-js"
  // native = dev (Windows/Mac); linux-musl-openssl-3.0.x = container Alpine (deploy).
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PLATAFORMA (sem tenantId — tabelas globais)
// ============================================================

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  name        String
  niche       String?  // colchoes | restaurante | salao | generico
  brandColor  String?  // cor da marca (white-label básico), ex: "#16a34a"
  logoUrl     String?  // URL do logo da loja
  status      TenantStatus @default(TRIAL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         TenantUser[]
  subscription  Subscription?
  botConfig     BotConfig?
  products      Product[]
  orders        Order[]
  conversations Conversation[]
  usageEvents   UsageEvent[]
  customers     Customer[]
  professionals Professional[]
  services      Service[]
  appointments  Appointment[]
  expenses      Expense[]
  productKitItems ProductKitItem[]

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELED
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenants  TenantUser[]
  sessions Session[]
  accounts Account[]

  @@map("users")
}

// ============================================================
// AUTH (Better-Auth schema)
// ============================================================

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model TenantUser {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  role      TenantRole @default(ADMIN)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

enum TenantRole {
  ADMIN
  OPERATOR
  FINANCIAL
  DELIVERY
}

model Subscription {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @unique @db.Uuid
  provider        String   // "asaas" | "stripe"
  providerSubId   String?
  plan            String   // "starter" | "pro"
  monthlyPriceBrl Decimal  @db.Decimal(10, 2)
  messageQuota    Int      // 2500 no plano starter
  status          String   // "trialing" | "active" | "past_due" | "canceled"
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================================
// CONFIGURAÇÃO DO BOT POR TENANT
// ============================================================

model BotConfig {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @unique @db.Uuid

  // Identidade
  botName            String   // "Gustavo"
  tone               String   @default("professional_casual")
  template           String   @default("generico") // template do nicho

  // Operação
  businessHours      Json     // { mon: { open: "08:00", close: "18:00" }, ... }
  deliveryCities     String[] // ["Goiânia", "Aparecida", "Senador Canedo"]
  paymentMethods     String[] // ["pix", "cartao", "boleto"]
  acceptsScheduling  Boolean  @default(false)
  dailyDeliveryCapacity Int   @default(0) // entregas/dia (0 = sem limite definido)

  // Prompt customizado pelo lojista
  extraInstructions  String   @default("") @db.Text

  // Conexão WhatsApp
  whatsappProvider   String   @default("evolution") // "evolution" | "meta_cloud"
  whatsappInstance   String?  // nome da instance Evolution ou phone_number_id Meta
  whatsappConnected  Boolean  @default(false)

  // LLM
  llmProvider        String   @default("google") // "anthropic" | "google" | "openai"
  llmModel           String   @default("gemini-2.5-flash")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("bot_configs")
}

// ============================================================
// DOMÍNIO (todas com tenantId)
// ============================================================

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String   // nome comercial (mostrado ao cliente/bot)
  fiscalName  String?  // nome da nota (p/ emissão fiscal); idealmente não editado após emitir
  description String?  @db.Text
  category    String?  // categoria livre (ou por nicho): "Casal", "Queen"...
  kind        String   @default("simple") // "simple" | "kit"
  priceBrl    Decimal  @db.Decimal(10, 2)
  costBrl     Decimal? @db.Decimal(10, 2) // custo, pra calcular margem
  imageUrl    String?  // imagem de catálogo
  realImageUrl String? // imagem "real" do produto
  stock       Int      @default(0)
  lowStockThreshold Int @default(5) // alerta quando stock <= este valor
  // Dados fiscais (estrutura pronta; emissão de nota vem no módulo fiscal)
  ncm         String?
  cest        String?
  cfopEntrada String?
  origem      String?  // origem da mercadoria (0-8)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kitItems   ProductKitItem[] @relation("KitComposition")
  partOfKits ProductKitItem[] @relation("KitComponentOf")

  @@index([tenantId, active])
  @@map("products")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  phone     String
  email     String?
  address   String?  @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Telefone é a chave natural do cliente (sistema é centrado em WhatsApp);
  // único por tenant pra permitir casar histórico de pedidos por telefone.
  @@unique([tenantId, phone])
  @@index([tenantId, createdAt])
  @@map("customers")
}

model ProductKitItem {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @db.Uuid
  kitId       String  @db.Uuid // produto tipo kit
  componentId String  @db.Uuid // produto componente
  qty         Int     @default(1)

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kit       Product @relation("KitComposition", fields: [kitId], references: [id], onDelete: Cascade)
  component Product @relation("KitComponentOf", fields: [componentId], references: [id], onDelete: Cascade)

  @@index([tenantId, kitId])
  @@map("product_kit_items")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  orderNumber     Int         // sequencial por tenant
  customerName    String
  customerPhone   String
  customerAddress String?     @db.Text // endereço montado (compatibilidade/exibição)
  // Cliente — identidade
  customerCpf     String?
  customerEmail   String?
  // Endereço estruturado
  cep             String?
  street          String?
  streetNumber    String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  // Venda — metadados
  channel         String      @default("presencial") // "online" | "presencial"
  sellerName      String? // responsável pela venda
  invoiceType     String      @default("none") // "none" | "nfce" | "nfe"
  toReceive       Boolean     @default(false) // a receber (ex: na entrega)
  // Entrega
  deliveryType    String      @default("delivery") // "delivery" | "pickup"
  deliveryDate    DateTime?
  deliveryShift   String? // "morning" | "afternoon"
  // Valores
  status          OrderStatus @default(PENDING)
  items           Json        // [{ productId, name, qty, priceBrl, discountBrl, freightBrl }]
  discountBrl     Decimal?    @db.Decimal(10, 2)
  freightBrl      Decimal?    @db.Decimal(10, 2)
  totalBrl        Decimal     @db.Decimal(10, 2)
  paymentMethod   String?
  installments    Int         @default(1) // parcelas (cartão)
  notes           String?     @db.Text
  scheduledFor    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status, createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_DELIVERY
  DELIVERED
  CANCELED
}

model Conversation {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  customerPhone   String
  customerName    String?
  lastMessageAt   DateTime @default(now())
  botPaused       Boolean  @default(false)
  botPausedUntil  DateTime?
  optOut          Boolean  @default(false)
  createdAt       DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([tenantId, customerPhone])
  @@index([tenantId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  role           String   // "user" | "assistant" | "system"
  content        String   @db.Text
  mediaType      String?  // "audio" | "image" | "pdf" | null
  mediaUrl       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model UsageEvent {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tokensIn     Int
  tokensOut    Int
  messageCount Int      @default(1)
  costBrl      Decimal  @db.Decimal(10, 4)
  llmProvider  String
  llmModel     String
  occurredAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
  @@map("usage_events")
}

// ============================================================
// AGENDAMENTO DE SERVIÇOS (nichos de serviço: estética, clínica...)
// ============================================================

model Professional {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId, active])
  @@map("professionals")
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  durationMin Int      @default(30)
  priceBrl    Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId, active])
  @@map("services")
}

model Appointment {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @db.Uuid
  professionalId String?           @db.Uuid
  serviceId      String?           @db.Uuid
  serviceName    String            // snapshot do serviço no momento
  customerName   String
  customerPhone  String
  scheduledFor   DateTime
  durationMin    Int               @default(30)
  priceBrl       Decimal           @default(0) @db.Decimal(10, 2)
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, scheduledFor])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  DONE
  CANCELED
  NO_SHOW
}

// ============================================================
// FINANCEIRO
// ============================================================

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  category    String   // "Fornecedor", "Aluguel", "Marketing", "Salário"...
  description String?
  amountBrl   Decimal  @db.Decimal(10, 2)
  paidAt      DateTime // data da despesa (competência)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, paidAt])
  @@map("expenses")
}
